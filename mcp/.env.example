# ── ESP v2 MCP Server Environment ────────────────────────────────────
# Copy to .env and fill in values before running MCP servers.

# ESP backend API base (no trailing slash)
ESP_API_BASE=http://localhost:8002/api

# Admin bearer token (get from: POST /api/v1/auth/login with admin@demo.esp / Demo1234!)
ESP_ADMIN_TOKEN=

# Nashmi integration
NASHMI_BASE_URL=https://nashmi.manager.eqratech.com
NASHMI_INTEGRATION_KEY=nashmi_secret_requrement_project_5152211

# Database (only used by nashmi-generator server)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=esp_v2
DB_USER=esp_user
DB_PASS=

# Nashmi generator pipeline path (only used by nashmi-generator server)
NASHMI_GEN_PATH=
SERVICES_OUT_DIR=../generated-services

# Schema generator (only used by schema-generator server)
ANTHROPIC_API_KEY=
SCHEMA_GEN_MODEL=claude-opus-4-8
