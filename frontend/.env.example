VITE_API_BASE_URL=http://localhost:8002/api/v1
VITE_INTEGRATION_KEY=your_integration_key_here

# JORD-55: captcha widget on the login screen. Off by default so dev
# installs don't need to solve a challenge on every sign-in. Set to
# "true" (and set CAPTCHA_ENABLED=true on the backend) to re-enable.
VITE_CAPTCHA_ENABLED=false
