APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# NFR-010: object storage for uploads. Production MUST use s3 (or r2/spaces/minio).
# StorageServiceProvider aborts boot in production if this is 'local' or 'public'.
# Dev may keep 'local' and get a warning at boot.
FILESYSTEM_DISK=local

# NFR-001: warn in api_access.log when a GET/HEAD request exceeds this budget (ms).
SLOW_REQUEST_MS=500

# NFR-006: audit log retention window. `audit:prune` deletes older rows monthly.
AUDIT_LOG_RETENTION_YEARS=7

# Text captcha (App\Services\CaptchaService, verified by VerifyCaptcha middleware).
# JORD-55: off by default so dev/demo installs don't need to solve a
# challenge on every login. Deployments that want bot mitigation set
# CAPTCHA_ENABLED=true here AND VITE_CAPTCHA_ENABLED=true on the frontend.
CAPTCHA_ENABLED=false
CAPTCHA_TTL_MINUTES=5

QUEUE_CONNECTION=sync

# JORD-56: Laravel 11+ defaults these to `database`, but the ESP repo
# does not ship the sessions / cache / jobs migrations — an SQLite dev
# clone therefore 500s on the first login with
# "no such table: cache" (the login throttle middleware reads cache
# before password validation, so the error surfaces immediately even
# though every other page still renders). `file` needs no schema so
# `php artisan migrate:fresh --seed` is enough for a fresh clone.
# Deployments that want DB-backed cache/session/queue must also add
# the matching migrations (`artisan cache:table` / `session:table` /
# `queue:table` and re-migrate).
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
